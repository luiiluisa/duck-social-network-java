<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="ui.fx.LoginController"
            prefWidth="420" prefHeight="260">

    <center>
        <VBox spacing="12" alignment="CENTER">
            <padding>
                <Insets top="24" right="24" bottom="24" left="24"/>
            </padding>

            <Label text="Login"
                   style="-fx-font-size: 20px; -fx-font-weight: bold;"/>

            <GridPane hgap="10" vgap="10">
                <Label text="Username / Email:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                <TextField fx:id="tfUser" promptText="username sau email"
                           GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                <Label text="Password:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                <PasswordField fx:id="pfPass" promptText="parola"
                               GridPane.rowIndex="1" GridPane.columnIndex="1"/>
            </GridPane>

            <Label fx:id="lblError"
                   text=""
                   style="-fx-text-fill: #c62828; -fx-font-weight: bold;"/>

            <HBox spacing="10" alignment="CENTER">
                <Button text="Login" onAction="#handleLogin" prefWidth="110"/>
                <Button text="Exit" onAction="#handleExit" prefWidth="110"/>
            </HBox>

        </VBox>
    </center>
</BorderPane>
