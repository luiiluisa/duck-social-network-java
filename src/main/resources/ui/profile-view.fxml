<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="ui.fx.ProfileController"
            prefWidth="1000" prefHeight="650">

    <!-- TOP BAR -->
    <top>
        <HBox spacing="10" alignment="CENTER_LEFT" style="-fx-padding: 12;">
            <Label text="Profile" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
            <Pane HBox.hgrow="ALWAYS"/>
            <Button text="Refresh" onAction="#handleRefresh"/>
        </HBox>
    </top>

    <center>
        <VBox spacing="14" style="-fx-padding: 18;">

            <!-- HEADER -->
            <HBox spacing="18" alignment="CENTER_LEFT">

                <!-- Avatar placeholder -->
                <StackPane prefWidth="120" prefHeight="120"
                           style="-fx-background-color: #eaeaea; -fx-background-radius: 60; -fx-border-radius: 60; -fx-border-color: #d0d0d0;">
                    <Label fx:id="lblAvatar" text="👤" style="-fx-font-size: 44px;"/>
                </StackPane>

                <VBox spacing="8">
                    <Label fx:id="lblUsername" text="@username" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>

                    <!-- SOCIAL STATS (ascunse automat pentru Duck) -->
                    <HBox fx:id="boxSocialStats" spacing="18">
                        <Label fx:id="lblFriends" text="Prieteni: 0"/>
                        <Label fx:id="lblPending" text="Cereri PENDING: 0"/>
                    </HBox>

                    <VBox spacing="2">
                        <Label fx:id="lblName" text="Nume" style="-fx-font-weight: bold;"/>
                        <Label fx:id="lblBio" text="Bio..." wrapText="true" maxWidth="520"/>
                        <Label fx:id="lblEmail" text="email@exemplu.com"/>
                    </VBox>
                </VBox>
            </HBox>

            <Separator/>

            <!-- QUICK NAV BUTTONS -->
            <HBox spacing="10">
                <Button fx:id="btnFriendRequests" text="Friend Requests" onAction="#openFriendRequests" prefWidth="180"/>
                <Button text="Messages" onAction="#openMessages" prefWidth="180"/>
                <Button text="RaceEvent" onAction="#openRaceEvent" prefWidth="180"/>
            </HBox>

            <Separator/>

            <!-- (Optional) content minim, dacă vrei să rămână gol nu pui nimic aici -->
            <Label text=""/>
        </VBox>
    </center>

</BorderPane>
