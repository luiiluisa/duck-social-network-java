<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml"
            fx:id="root"
            fx:controller="ui.fx.MessagesController"
            prefWidth="900" prefHeight="600">

    <top>
        <HBox spacing="10" alignment="CENTER_LEFT" style="-fx-padding: 10;">
            <Label fx:id="lblMe" text="Logged: -" style="-fx-font-weight: bold;"/>
            <Pane HBox.hgrow="ALWAYS"/>
            <Button text="Refresh" onAction="#handleRefresh"/>
        </HBox>
    </top>

    <left>
        <VBox spacing="8" style="-fx-padding: 10;" prefWidth="260">
            <Label text="Users" style="-fx-font-size: 14px; -fx-font-weight: bold;"/>
            <TextField fx:id="tfSearch" promptText="search username/email" onKeyReleased="#handleSearch"/>
            <ListView fx:id="listUsers" VBox.vgrow="ALWAYS"/>
        </VBox>
    </left>

    <center>
        <BorderPane style="-fx-padding: 10;">
            <top>
                <Label fx:id="lblChatWith"
                       text="Conversation: (select a user)"
                       style="-fx-font-size: 14px; -fx-font-weight: bold;"/>
            </top>

            <center>
                <ListView fx:id="listMessages" prefHeight="400"/>
            </center>

            <bottom>
                <VBox spacing="8" style="-fx-padding: 10;">
                    <HBox spacing="10" alignment="CENTER_LEFT">
                        <Label text="Reply to:"/>
                        <Label fx:id="lblReply" text="(none)"/>
                        <Pane HBox.hgrow="ALWAYS"/>
                        <Button text="Clear reply" onAction="#clearReply"/>
                    </HBox>

                    <HBox spacing="10">
                        <TextField fx:id="tfMessage" promptText="Type a message..." HBox.hgrow="ALWAYS"/>
                        <Button text="Send" onAction="#handleSend" prefWidth="100"/>
                    </HBox>
                </VBox>
            </bottom>
        </BorderPane>
    </center>

</BorderPane>
