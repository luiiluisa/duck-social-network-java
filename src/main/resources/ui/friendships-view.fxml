<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="ui.fx.FriendshipsController"
            prefWidth="700"
            prefHeight="450"
            style="-fx-padding: 20;">

    <top>
        <VBox spacing="8">

            <Label text="Friendships &amp; Communities"
                   style="-fx-font-size: 18px; -fx-font-weight: bold;"/>

            <Label text="Friendships list:"
                   style="-fx-font-size: 14px; -fx-font-weight: bold;"/>

            <TableView fx:id="tableFriendships" prefHeight="220">
                <columns>
                    <TableColumn fx:id="colFUser1Id"    text="User1 ID"       prefWidth="80"/>
                    <TableColumn fx:id="colFUser1Name"  text="User1 Username" prefWidth="150"/>
                    <TableColumn fx:id="colFUser2Id"    text="User2 ID"       prefWidth="80"/>
                    <TableColumn fx:id="colFUser2Name"  text="User2 Username" prefWidth="150"/>
                </columns>
            </TableView>

        </VBox>
    </top>

    <center>
        <VBox spacing="12" style="-fx-padding: 10 0 0 0;">

            <!-- ADD FRIENDSHIP -->
            <Label text="Add Friendship"
                   style="-fx-font-size: 14px; -fx-font-weight: bold;"/>

            <HBox spacing="10" alignment="CENTER_LEFT">
                <Label text="User 1:"/>
                <ComboBox fx:id="comboAddUser1" prefWidth="220"/>
                <Label text="User 2:"/>
                <ComboBox fx:id="comboAddUser2" prefWidth="220"/>
            </HBox>

            <HBox spacing="10">
                <Button text="Add friendship" onAction="#handleAddFriendship"/>
                <Button text="Delete selected" onAction="#handleRemoveSelected"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="Open communities" onAction="#handleOpenCommunities"/>
            </HBox>

        </VBox>
    </center>

</BorderPane>
